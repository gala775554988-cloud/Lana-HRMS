# Copy to tests/smoke/.env.smoke (gitignored) and fill in real values before
# running `npm run test:smoke`. Never commit real credentials.
#
# SMOKE_BASE_URL defaults to http://localhost:3000 — point it at a real
# environment only if you understand the smoke tests will create and delete
# an "announcements" record there.
SMOKE_BASE_URL=http://localhost:3000

SMOKE_SUPER_ADMIN_ID=
SMOKE_SUPER_ADMIN_PASSWORD=

SMOKE_HR_MANAGER_ID=
SMOKE_HR_MANAGER_PASSWORD=

SMOKE_EMPLOYEE_ID=
SMOKE_EMPLOYEE_PASSWORD=
