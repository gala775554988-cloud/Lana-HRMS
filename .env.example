# Database - Supabase/PostgreSQL
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# Supabase
SUPABASE_URL="https://[PROJECT_REF].supabase.co"
SUPABASE_ANON_KEY="replace-with-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="replace-with-supabase-service-role-key"

# Auth.js / NextAuth v5
AUTH_SECRET="replace-with-a-secure-random-secret"
AUTH_TRUST_HOST="true"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-secure-random-secret"
APP_URL="http://localhost:3000"

# PWA / installable app
# In production set both URLs to your HTTPS domain, for example:
# NEXTAUTH_URL="https://hrms.example.com"
# APP_URL="https://hrms.example.com"

# Odoo integration (server-side only; never expose these with NEXT_PUBLIC_)
ODOO_URL="https://your-odoo.example.com"
ODOO_DATABASE="your_odoo_database"
ODOO_USERNAME="integration-user@example.com"
ODOO_PASSWORD="replace-with-odoo-password"
# Optional: preferred for production. When set, it is used instead of ODOO_PASSWORD.
ODOO_API_KEY=""
# Optional: auto, json-rpc, or xml-rpc. auto prefers JSON-RPC and falls back to XML-RPC.
ODOO_PROTOCOL="auto"

# Shared secret Vercel Cron sends as "Authorization: Bearer <value>" to authenticate
# the hourly /api/integrations/odoo/cron-sync call (no user session exists for cron runs).
CRON_SECRET="replace-with-a-secure-random-secret"

# Lana AI -- Gemini is the primary LLM provider (streaming + tool calling).
# Get a key from https://aistudio.google.com/apikey
GEMINI_API_KEY=""
# Optional: defaults to "gemini-flash-latest" (auto-tracks Google's current
# stable flash release) if unset.
GEMINI_MODEL=""
# Optional fallback provider, used only if GEMINI_API_KEY is not set.
OPENAI_API_KEY=""
OPENAI_MODEL=""

# Seeded access
# Admin login is username/password: admin / Admin@123456
# Sample employee login is national ID/password: 1000000001 / Employee@123456
SEED_ADMIN_EMAIL="admin@lana.local"
