# Database - Supabase/PostgreSQL
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# Supabase
SUPABASE_URL="https://[PROJECT_REF].supabase.co"
SUPABASE_ANON_KEY="replace-with-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="replace-with-supabase-service-role-key"

# Auth.js / NextAuth v5
AUTH_SECRET="replace-with-a-secure-random-secret"
AUTH_TRUST_HOST="true"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-secure-random-secret"
APP_URL="http://localhost:3000"

# Seeded access
# Admin login is username/password: admin / Admin@123456
# Sample employee login is national ID/password: 1000000001 / Employee@123456
SEED_ADMIN_EMAIL="admin@lana.local"
