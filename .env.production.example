# Lana HRMS - Production Environment Variables
# انسخ القيم إلى Vercel > Project Settings > Environment Variables

# Supabase/PostgreSQL
# DATABASE_URL يفضل يكون من Pooler/Transaction pooler للإنتاج
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@[POOLER_HOST]:6543/postgres?pgbouncer=true&connection_limit=1"

# DIRECT_URL يكون رابط الاتصال المباشر لعمليات Prisma migrate
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# Supabase API
SUPABASE_URL="https://[PROJECT_REF].supabase.co"
SUPABASE_ANON_KEY="replace-with-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="replace-with-supabase-service-role-key"

# Auth.js / NextAuth
# غيّر your-domain.com إلى رابط Vercel النهائي أو الدومين الخاص بك
AUTH_SECRET="replace-with-secure-random-secret"
NEXTAUTH_SECRET="replace-with-secure-random-secret"
NEXTAUTH_URL="https://your-domain.com"
APP_URL="https://your-domain.com"
AUTH_TRUST_HOST="true"

# Odoo integration (server-side only; configure in Vercel Project Settings)
ODOO_URL="https://your-odoo.example.com"
ODOO_DATABASE="your_odoo_database"
ODOO_USERNAME="integration-user@example.com"
ODOO_PASSWORD="replace-with-odoo-password"
# Optional: preferred for production. When set, it is used instead of ODOO_PASSWORD.
ODOO_API_KEY=""
ODOO_PROTOCOL="auto"

# Seeded access
SEED_ADMIN_EMAIL="admin@lana.local"
