generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                      String                   @id @default(cuid())
  name                    String?
  username                String?                  @unique
  email                   String?                  @unique
  emailVerified           DateTime?
  image                   String?
  passwordHash            String?
  isActive                Boolean                  @default(true)
  lastLoginAt             DateTime?
  mustChangePassword      Boolean                  @default(false)
  passwordChanged         Boolean                  @default(true)
  passwordChangedAt       DateTime?
  lastPasswordResetBy     String?
  lastPasswordResetAt     DateTime?
  isLocked                Boolean                  @default(false)
  lockedReason            String?
  lockedAt                DateTime?
  lockedById              String?
  loginAttempts           Int                      @default(0)
  lastFailedLoginAt       DateTime?
  loginCount              Int                      @default(0)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  accounts                Account[]
  sessions                Session[]
  roles                   UserRole[]
  customPermissions       UserPermission[]
  grantedPermissions      UserPermission[]         @relation("PermissionGrantedBy")
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  employeeProfile         Employee?
  auditLogs               AuditLog[]
  auditPermissionActions  AuditPermissionLog[]     @relation("AuditActor")
  auditPermissionTargets  AuditPermissionLog[]     @relation("AuditTarget")
  notifications           Notification[]

  @@index([username])
  @@index([email])
  @@index([mustChangePassword])
  @@index([passwordChanged])
  @@index([isLocked])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Role {
  id                  String               @id @default(cuid())
  name                String               @unique
  description         String?
  isSystem            Boolean              @default(false)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  users               UserRole[]
  permissions         RolePermission[]
  auditPermissionLogs AuditPermissionLog[]
}

model Permission {
  id              String               @id @default(cuid())
  action          String
  resource        String
  description     String?
  groupCode       String?
  isSystem        Boolean              @default(false)
  sortOrder       Int                  @default(0)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  roles           RolePermission[]
  userPermissions UserPermission[]
  auditLogs       AuditPermissionLog[]

  @@unique([action, resource])
  @@index([groupCode])
  @@index([isSystem])
}

model PermissionGroup {
  id          String   @id @default(cuid())
  code        String   @unique
  key         String?  @unique
  name        String
  nameAr      String?
  description String?
  icon        String?
  parentId    String?
  isSystem    Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([code])
  @@index([key])
}

model UserPermission {
  id           String     @id @default(cuid())
  userId       String
  permissionId String
  isGranted    Boolean    @default(true)
  grantedById  String?
  grantedAt    DateTime   @default(now())
  expiresAt    DateTime?
  reason       String?
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  grantedBy    User?      @relation("PermissionGrantedBy", fields: [grantedById], references: [id], onDelete: SetNull)

  @@unique([userId, permissionId])
  @@index([userId])
  @@index([permissionId])
  @@index([isGranted])
}

model AuditPermissionLog {
  id           String      @id @default(cuid())
  actorUserId  String?
  targetUserId String?
  action       String
  permissionId String?
  roleId       String?
  oldValue     Json?
  newValue     Json?
  ipAddress    String?
  userAgent    String?
  device       String?
  createdAt    DateTime    @default(now())
  actor        User?       @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  target       User?       @relation("AuditTarget", fields: [targetUserId], references: [id], onDelete: SetNull)
  permission   Permission? @relation(fields: [permissionId], references: [id], onDelete: SetNull)
  role         Role?       @relation(fields: [roleId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([targetUserId])
  @@index([createdAt])
}

model UserRole {
  userId     String
  roleId     String
  assignedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String
  assignedAt   DateTime   @default(now())
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

enum EmployeeStatus {
  ACTIVE
  ON_LEAVE
  TERMINATED
  INACTIVE
}

enum DocumentStatus {
  PENDING
  VERIFIED
  REJECTED
  EXPIRED
}

enum ContractStatus {
  DRAFT
  ACTIVE
  EXPIRED
  TERMINATED
}

model Department {
  id            String     @id @default(cuid())
  name          String
  code          String     @unique
  description   String?
  isActive      Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  employees     Employee[]
  positions     Position[]
  odooId        Int?       @unique
  odooWriteDate DateTime?
  odooActive    Boolean?

  @@index([name])
  @@index([odooId])
}

model Position {
  id               String      @id @default(cuid())
  title            String
  code             String      @unique
  description      String?
  departmentId     String?
  isActive         Boolean     @default(true)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  department       Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  employees        Employee[]
  odooId           Int?        @unique
  odooWriteDate    DateTime?
  odooDepartmentId Int?

  @@index([title])
  @@index([departmentId])
  @@index([odooId])
}

model Branch {
  id            String     @id @default(cuid())
  name          String
  code          String     @unique
  address       String?
  city          String?
  country       String?
  isActive      Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  employees     Employee[]
  odooId        Int?       @unique
  odooWriteDate DateTime?
  odooActive    Boolean?

  @@index([name])
  @@index([odooId])
}

model EmploymentType {
  id          String     @id @default(cuid())
  name        String
  code        String     @unique
  description String?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  employees   Employee[]
}

model Nationality {
  id        String     @id @default(cuid())
  name      String
  code      String     @unique
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  employees Employee[]
}

model Employee {
  id                     String                  @id @default(cuid())
  employeeNumber         String                  @unique
  nationalId             String                  @unique
  firstName              String
  lastName               String
  email                  String?                 @unique
  profilePhotoUrl        String?
  phone                  String?
  gender                 String?
  dateOfBirth            DateTime?
  hireDate               DateTime
  terminationDate        DateTime?
  status                 EmployeeStatus          @default(ACTIVE)
  address                String?
  emergencyContact       String?
  userId                 String?                 @unique
  departmentId           String?
  positionId             String?
  branchId               String?
  employmentTypeId       String?
  nationalityId          String?
  // Archived employees & last active date
  managerId              String?
  lastActiveDate         DateTime?
  lastActiveSource       String? // e.g., "ODOO", "ATTENDANCE", "LEAVE", "TIMESHEET"
  archivedAt             DateTime?
  archiveReason          String?
  isPendingActivation    Boolean                 @default(false)
  pendingActivationUntil DateTime?
  // Odoo Source of Truth fields
  odooId                 Int?                    @unique
  odooWriteDate          DateTime?
  odooCreateDate         DateTime?
  odooActive             Boolean?
  odooDepartmentId       Int?
  odooJobId              Int?
  odooCompanyId          Int?
  odooParentId           Int?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  user                   User?                   @relation(fields: [userId], references: [id], onDelete: SetNull)
  department             Department?             @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  position               Position?               @relation(fields: [positionId], references: [id], onDelete: SetNull)
  branch                 Branch?                 @relation(fields: [branchId], references: [id], onDelete: SetNull)
  employmentType         EmploymentType?         @relation(fields: [employmentTypeId], references: [id], onDelete: SetNull)
  nationality            Nationality?            @relation(fields: [nationalityId], references: [id], onDelete: SetNull)
  manager                Employee?               @relation("EmployeeManager", fields: [managerId], references: [id], onDelete: SetNull)
  managedEmployees       Employee[]              @relation("EmployeeManager")
  documents              EmployeeDocument[]
  contracts              EmployeeContract[]
  assignedAssets         Asset[]
  trainingEnrollments    TrainingEnrollment[]
  evaluations            PerformanceEvaluation[]
  deductions             Deduction[]
  allowances             Allowance[]
  overtimeRequests       OvertimeRequest[]
  loans                  Loan[]
  payrollItems           PayrollItem[]
  leaveRequests          LeaveRequest[]
  attendanceRecords      AttendanceRecord[]
  preferences            EmployeePreference?
  workflowInstances      WorkflowInstance[]
  expenseRequests        ExpenseRequest[]
  letterRequests         LetterRequest[]

  bankAccounts       EmployeeBankAccount[]
  familyMembers      EmployeeFamilyMember[]
  qualifications     EmployeeQualification[]
  experiences        EmployeeExperience[]
  skills             EmployeeSkill[]
  languages          EmployeeLanguage[]
  permissionRequests EmployeePermissionRequest[]
  portalTasks        EmployeePortalTask[]
  chatThreads        EmployeeChatThread[]

  @@index([nationalId])
  @@index([firstName, lastName])
  @@index([status])
  @@index([departmentId])
  @@index([positionId])
  @@index([branchId])
  @@index([email])
  @@index([employeeNumber])
  @@index([lastActiveDate])
  @@index([archivedAt])
  @@index([managerId])
  @@index([isPendingActivation])
  @@index([pendingActivationUntil])
  @@index([hireDate])
  @@index([createdAt])
  @@index([status, departmentId])
  @@index([status, branchId])
}

model EmployeeDocument {
  id         String         @id @default(cuid())
  employeeId String
  type       String
  name       String
  fileUrl    String
  fileName   String?
  mimeType   String?
  sizeBytes  Int?
  status     DocumentStatus @default(PENDING)
  expiresAt  DateTime?
  uploadedAt DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  employee   Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([status])
}

model EmployeeContract {
  id             String         @id @default(cuid())
  employeeId     String
  contractNumber String         @unique
  title          String
  startDate      DateTime
  endDate        DateTime?
  salaryAmount   Decimal        @db.Decimal(12, 2)
  currency       String         @default("USD")
  status         ContractStatus @default(DRAFT)
  signedAt       DateTime?
  attachmentUrl  String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  employee       Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  odooId         Int?           @unique
  odooEmployeeId Int?
  odooWriteDate  DateTime?
  odooState      String?

  @@index([employeeId])
  @@index([status])
  @@index([odooId])
  @@index([odooEmployeeId])
}

model SalaryStructure {
  id          String            @id @default(cuid())
  code        String            @unique
  name        String
  description String?
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  components  SalaryComponent[]

  @@index([code])
  @@index([isActive])
}

model SalaryComponent {
  id          String          @id @default(cuid())
  structureId String
  code        String
  name        String
  type        String // EARNING, DEDUCTION
  amountType  String // FIXED, PERCENTAGE, FORMULA
  amount      Decimal?        @db.Decimal(12, 2)
  formula     String?
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  structure   SalaryStructure @relation(fields: [structureId], references: [id], onDelete: Cascade)

  @@unique([structureId, code])
  @@index([structureId])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  action      String
  entity      String
  entityId    String?
  metadata    Json?
  createdAt   DateTime @default(now())
  actor       User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([entity, entityId])
  @@index([createdAt])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  REMOTE
  HOLIDAY
}

enum LeaveRequestStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum PayrollStatus {
  DRAFT
  PROCESSING
  APPROVED
  PAID
  CANCELLED
}

enum LoanStatus {
  ACTIVE
  PAID
  DEFAULTED
  CANCELLED
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum EvaluationStatus {
  DRAFT
  SUBMITTED
  APPROVED
}

enum CandidateStatus {
  APPLIED
  SCREENING
  INTERVIEW
  OFFERED
  HIRED
  REJECTED
}

enum TrainingStatus {
  PLANNED
  OPEN
  COMPLETED
  CANCELLED
}

enum AssetStatus {
  AVAILABLE
  ASSIGNED
  MAINTENANCE
  RETIRED
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
}

model AttendanceRecord {
  id         String           @id @default(cuid())
  employeeId String
  workDate   DateTime
  checkIn    DateTime?
  checkOut   DateTime?
  status     AttendanceStatus @default(PRESENT)
  notes      String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  employee   Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, workDate])
  @@index([workDate])
  @@index([status])
}

model LeaveType {
  id          String         @id @default(cuid())
  name        String
  code        String         @unique
  description String?
  annualLimit Int?
  isPaid      Boolean        @default(true)
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  requests    LeaveRequest[]
}

model LeaveRequest {
  id           String             @id @default(cuid())
  employeeId   String
  leaveTypeId  String
  startDate    DateTime
  endDate      DateTime
  days         Decimal            @db.Decimal(6, 2)
  reason       String?
  status       LeaveRequestStatus @default(PENDING)
  decidedAt    DateTime?
  decisionNote String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  employee     Employee           @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType    LeaveType          @relation(fields: [leaveTypeId], references: [id], onDelete: Restrict)

  @@index([employeeId])
  @@index([leaveTypeId])
  @@index([status])
}

model PayrollRun {
  id        String        @id @default(cuid())
  name      String
  period    String
  status    PayrollStatus @default(DRAFT)
  paidAt    DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  items     PayrollItem[]

  @@unique([period])
  @@index([status])
}

model PayrollItem {
  id             String     @id @default(cuid())
  payrollRunId   String
  employeeId     String
  baseSalary     Decimal    @db.Decimal(12, 2)
  allowanceTotal Decimal    @default(0) @db.Decimal(12, 2)
  deductionTotal Decimal    @default(0) @db.Decimal(12, 2)
  overtimeTotal  Decimal    @default(0) @db.Decimal(12, 2)
  netPay         Decimal    @db.Decimal(12, 2)
  currency       String     @default("USD")
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  payrollRun     PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employee       Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([payrollRunId, employeeId])
  @@index([employeeId])
}

model Loan {
  id                String     @id @default(cuid())
  employeeId        String
  loanNumber        String     @unique
  principalAmount   Decimal    @db.Decimal(12, 2)
  outstandingAmount Decimal    @db.Decimal(12, 2)
  installmentAmount Decimal    @db.Decimal(12, 2)
  currency          String     @default("USD")
  issuedAt          DateTime
  status            LoanStatus @default(ACTIVE)
  notes             String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  employee          Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([status])
}

model OvertimeRequest {
  id         String        @id @default(cuid())
  employeeId String
  workDate   DateTime
  hours      Decimal       @db.Decimal(6, 2)
  rate       Decimal       @default(1.5) @db.Decimal(8, 2)
  reason     String?
  status     RequestStatus @default(PENDING)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  employee   Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([status])
}

model Allowance {
  id            String    @id @default(cuid())
  employeeId    String
  name          String
  amount        Decimal   @db.Decimal(12, 2)
  currency      String    @default("USD")
  effectiveFrom DateTime
  effectiveTo   DateTime?
  isRecurring   Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  employee      Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

model Deduction {
  id            String    @id @default(cuid())
  employeeId    String
  name          String
  amount        Decimal   @db.Decimal(12, 2)
  currency      String    @default("USD")
  effectiveFrom DateTime
  effectiveTo   DateTime?
  isRecurring   Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  employee      Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

model PerformanceEvaluation {
  id          String           @id @default(cuid())
  employeeId  String
  period      String
  score       Decimal          @db.Decimal(5, 2)
  summary     String?
  goals       String?
  status      EvaluationStatus @default(DRAFT)
  evaluatedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  employee    Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, period])
  @@index([status])
}

model JobOpening {
  id           String      @id @default(cuid())
  title        String
  code         String      @unique
  departmentId String?
  branchId     String?
  description  String?
  status       String      @default("OPEN")
  openedAt     DateTime    @default(now())
  closedAt     DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  candidates   Candidate[]

  @@index([status])
}

model Candidate {
  id           String          @id @default(cuid())
  jobOpeningId String?
  firstName    String
  lastName     String
  email        String
  phone        String?
  resumeUrl    String?
  status       CandidateStatus @default(APPLIED)
  notes        String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  jobOpening   JobOpening?     @relation(fields: [jobOpeningId], references: [id], onDelete: SetNull)

  @@index([firstName, lastName])
  @@index([email])
  @@index([status])
}

model TrainingProgram {
  id          String               @id @default(cuid())
  title       String
  code        String               @unique
  provider    String?
  startDate   DateTime?
  endDate     DateTime?
  status      TrainingStatus       @default(PLANNED)
  description String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  enrollments TrainingEnrollment[]
}

model TrainingEnrollment {
  id                String          @id @default(cuid())
  trainingProgramId String
  employeeId        String
  status            TrainingStatus  @default(OPEN)
  completedAt       DateTime?
  score             Decimal?        @db.Decimal(5, 2)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  trainingProgram   TrainingProgram @relation(fields: [trainingProgramId], references: [id], onDelete: Cascade)
  employee          Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([trainingProgramId, employeeId])
  @@index([employeeId])
}

model Asset {
  id                 String      @id @default(cuid())
  assetTag           String      @unique
  name               String
  category           String
  serialNumber       String?
  status             AssetStatus @default(AVAILABLE)
  assignedEmployeeId String?
  assignedAt         DateTime?
  returnedAt         DateTime?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  assignedEmployee   Employee?   @relation(fields: [assignedEmployeeId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([assignedEmployeeId])
}

model Announcement {
  id          String    @id @default(cuid())
  title       String
  body        String
  audience    String    @default("ALL")
  publishedAt DateTime?
  expiresAt   DateTime?
  isPublished Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([isPublished])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String?
  title     String
  body      String
  type      NotificationType @default(INFO)
  readAt    DateTime?
  createdAt DateTime         @default(now())
  user      User?            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([readAt])
}

model ReportDefinition {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  description String?
  module      String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AppSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  description String?
  isSecret    Boolean  @default(false)
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}

// ====================== EMPLOYEE PREFERENCES & THEMES ======================
model EmployeePreference {
  id            String   @id @default(cuid())
  employeeId    String   @unique
  theme         String   @default("corporate")
  language      String   @default("ar")
  timezone      String   @default("Asia/Riyadh")
  notifications Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

// ====================== SEPARATE REQUEST TABLES ======================
model ExpenseRequest {
  id          String        @id @default(cuid())
  employeeId  String
  amount      Decimal       @db.Decimal(12, 2)
  category    String
  description String?
  receiptUrl  String?
  status      RequestStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  employee    Employee      @relation(fields: [employeeId], references: [id])
}

model LetterRequest {
  id         String        @id @default(cuid())
  employeeId String
  letterType String
  purpose    String?
  status     RequestStatus @default(PENDING)
  fileUrl    String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  employee   Employee      @relation(fields: [employeeId], references: [id])
}

// ====================== WORKFLOW ENGINE ======================
model WorkflowInstance {
  id          String         @id @default(cuid())
  employeeId  String
  type        String // LEAVE | EXPENSE | LOAN | LETTER
  entityId    String
  status      String         @default("PENDING")
  currentStep Int            @default(1)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  employee    Employee       @relation(fields: [employeeId], references: [id])
  steps       WorkflowStep[]
}

model WorkflowStep {
  id                 String           @id @default(cuid())
  workflowInstanceId String
  step               Int
  approverUserId     String?
  status             String           @default("PENDING") // PENDING | APPROVED | REJECTED
  approvedAt         DateTime?
  comments           String?
  createdAt          DateTime         @default(now())
  workflowInstance   WorkflowInstance @relation(fields: [workflowInstanceId], references: [id], onDelete: Cascade)
}

// ====================== ENTERPRISE UPGRADE MODELS ======================

model Hospital {
  id           String   @id @default(cuid())
  name         String
  code         String   @unique
  logoUrl      String?
  medicalDepts String?
  bedsCount    Int      @default(0)
  capacity     Int      @default(0)
  phone        String?
  email        String?
  address      String?
  city         String?
  branchId     String?
  managerId    String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model DynamicField {
  id         String   @id @default(cuid())
  module     String // e.g., "EMPLOYEE", "DEPARTMENT"
  fieldName  String
  fieldType  String // e.g., "TEXT", "NUMBER", "DATE", "SELECT"
  options    Json?
  isRequired Boolean  @default(false)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model AILog {
  id        String   @id @default(cuid())
  action    String
  prompt    String?  @db.Text
  response  String?  @db.Text
  userId    String?
  createdAt DateTime @default(now())
}

// ====================== ENTERPRISE ERP INTEGRATIONS ======================
model IntegrationProvider {
  id           String                   @id @default(cuid())
  name         String
  code         String                   @unique
  type         String                   @default("ODOO")
  baseUrl      String
  authType     String                   @default("ODOO_JSON_RPC")
  isActive     Boolean                  @default(true)
  metadata     Json?
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  connections  IntegrationConnection[]
  mappings     IntegrationMapping[]
  jobs         IntegrationJob[]
  queues       IntegrationQueue[]
  webhooks     IntegrationWebhook[]
  apiKeys      IntegrationApiKey[]
  oauthClients IntegrationOAuthClient[]
  settings     IntegrationSetting[]
  logs         IntegrationLog[]

  @@index([type])
  @@index([isActive])
}

model IntegrationConnection {
  id            String               @id @default(cuid())
  providerId    String
  name          String
  baseUrl       String
  database      String?
  username      String?
  uid           Int?
  sessionId     String?
  secretCipher  String?
  status        String               @default("DISCONNECTED")
  lastTestAt    DateTime?
  lastError     String?
  version       Json?
  metadata      Json?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  provider      IntegrationProvider  @relation(fields: [providerId], references: [id], onDelete: Cascade)
  mappings      IntegrationMapping[]
  jobs          IntegrationJob[]
  queues        IntegrationQueue[]
  syncHistories SyncHistory[]
  conflicts     ConflictLog[]
  logs          IntegrationLog[]

  @@index([providerId])
  @@index([status])
}

model IntegrationMapping {
  id               String                 @id @default(cuid())
  providerId       String
  connectionId     String?
  name             String
  hrmsModule       String
  hrmsModel        String
  externalModel    String
  direction        String                 @default("BIDIRECTIONAL")
  keyField         String                 @default("id")
  externalKeyField String                 @default("id")
  fieldMap         Json
  transformMap     Json?
  isActive         Boolean                @default(true)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  provider         IntegrationProvider    @relation(fields: [providerId], references: [id], onDelete: Cascade)
  connection       IntegrationConnection? @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  jobs             IntegrationJob[]
  queues           IntegrationQueue[]
  syncHistories    SyncHistory[]
  conflicts        ConflictLog[]

  @@index([providerId])
  @@index([connectionId])
  @@index([hrmsModule])
  @@index([externalModel])
  @@index([isActive])
}

model IntegrationJob {
  id           String                 @id @default(cuid())
  providerId   String?
  connectionId String?
  mappingId    String?
  name         String
  type         String
  status       String                 @default("PENDING")
  direction    String                 @default("BIDIRECTIONAL")
  schedule     String?
  payload      Json?
  result       Json?
  attempts     Int                    @default(0)
  maxAttempts  Int                    @default(3)
  runAt        DateTime?
  startedAt    DateTime?
  finishedAt   DateTime?
  lastError    String?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  provider     IntegrationProvider?   @relation(fields: [providerId], references: [id], onDelete: SetNull)
  connection   IntegrationConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)
  mapping      IntegrationMapping?    @relation(fields: [mappingId], references: [id], onDelete: SetNull)
  queues       IntegrationQueue[]
  logs         IntegrationLog[]

  @@index([status])
  @@index([type])
  @@index([runAt])
  @@index([connectionId])
}

model IntegrationQueue {
  id           String                 @id @default(cuid())
  providerId   String?
  connectionId String?
  mappingId    String?
  jobId        String?
  queueName    String                 @default("default")
  status       String                 @default("PENDING")
  direction    String                 @default("BIDIRECTIONAL")
  operation    String
  entity       String
  entityId     String?
  externalId   String?
  payload      Json
  result       Json?
  attempts     Int                    @default(0)
  maxAttempts  Int                    @default(5)
  availableAt  DateTime               @default(now())
  lockedAt     DateTime?
  processedAt  DateTime?
  deadLetterAt DateTime?
  lastError    String?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  provider     IntegrationProvider?   @relation(fields: [providerId], references: [id], onDelete: SetNull)
  connection   IntegrationConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)
  mapping      IntegrationMapping?    @relation(fields: [mappingId], references: [id], onDelete: SetNull)
  job          IntegrationJob?        @relation(fields: [jobId], references: [id], onDelete: SetNull)
  logs         IntegrationLog[]

  @@index([status])
  @@index([queueName])
  @@index([availableAt])
  @@index([connectionId])
  @@index([entity, entityId])
}

model IntegrationWebhook {
  id             String               @id @default(cuid())
  providerId     String?
  name           String
  url            String
  secretCipher   String?
  events         Json
  isActive       Boolean              @default(true)
  lastDeliveryAt DateTime?
  lastStatus     String?
  metadata       Json?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  provider       IntegrationProvider? @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@index([isActive])
}

model IntegrationLog {
  id           String                 @id @default(cuid())
  providerId   String?
  connectionId String?
  jobId        String?
  queueId      String?
  level        String                 @default("INFO")
  action       String
  message      String
  request      Json?
  response     Json?
  metadata     Json?
  createdAt    DateTime               @default(now())
  provider     IntegrationProvider?   @relation(fields: [providerId], references: [id], onDelete: SetNull)
  connection   IntegrationConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)
  job          IntegrationJob?        @relation(fields: [jobId], references: [id], onDelete: SetNull)
  queue        IntegrationQueue?      @relation(fields: [queueId], references: [id], onDelete: SetNull)

  @@index([level])
  @@index([action])
  @@index([createdAt])
  @@index([connectionId])
}

model IntegrationApiKey {
  id           String               @id @default(cuid())
  providerId   String?
  name         String
  keyHash      String               @unique
  secretCipher String?
  scopes       Json
  expiresAt    DateTime?
  lastUsedAt   DateTime?
  isActive     Boolean              @default(true)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  provider     IntegrationProvider? @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@index([isActive])
}

model IntegrationOAuthClient {
  id                 String               @id @default(cuid())
  providerId         String?
  name               String
  clientId           String               @unique
  clientSecretCipher String
  redirectUris       Json
  scopes             Json
  grants             Json
  isActive           Boolean              @default(true)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  provider           IntegrationProvider? @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@index([isActive])
}

model IntegrationSetting {
  id          String               @id @default(cuid())
  providerId  String?
  key         String
  value       Json
  isSecret    Boolean              @default(false)
  description String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  provider    IntegrationProvider? @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([providerId, key])
  @@index([key])
}

model SyncHistory {
  id            String                @id @default(cuid())
  connectionId  String
  mappingId     String?
  direction     String
  entity        String
  startedAt     DateTime              @default(now())
  finishedAt    DateTime?
  status        String                @default("RUNNING")
  pulled        Int                   @default(0)
  pushed        Int                   @default(0)
  createdCount  Int                   @default(0)
  updatedCount  Int                   @default(0)
  deletedCount  Int                   @default(0)
  conflictCount Int                   @default(0)
  cursor        String?
  error         String?
  metadata      Json?
  connection    IntegrationConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  mapping       IntegrationMapping?   @relation(fields: [mappingId], references: [id], onDelete: SetNull)

  @@index([connectionId])
  @@index([mappingId])
  @@index([status])
  @@index([startedAt])
}

model ConflictLog {
  id            String                @id @default(cuid())
  connectionId  String
  mappingId     String?
  entity        String
  localId       String?
  externalId    String?
  field         String?
  localValue    Json?
  externalValue Json?
  resolution    String                @default("PENDING")
  resolvedValue Json?
  resolvedById  String?
  resolvedAt    DateTime?
  metadata      Json?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  connection    IntegrationConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  mapping       IntegrationMapping?   @relation(fields: [mappingId], references: [id], onDelete: SetNull)

  @@index([connectionId])
  @@index([mappingId])
  @@index([resolution])
  @@index([entity])
}

// ====================== ENTERPRISE PROCESS SUITES ======================
model EnterpriseRecord {
  id              String    @id @default(cuid())
  suite           String
  feature         String
  code            String
  title           String
  status          String    @default("ACTIVE")
  priority        String    @default("NORMAL")
  ownerEmployeeId String?
  effectiveFrom   DateTime?
  effectiveTo     DateTime?
  data            Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([suite, feature, code])
  @@index([suite])
  @@index([feature])
  @@index([status])
  @@index([ownerEmployeeId])
}

model EnterpriseWorkflowTemplate {
  id         String   @id @default(cuid())
  suite      String
  feature    String
  name       String
  steps      Json
  conditions Json?
  slaHours   Int?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([suite, feature])
  @@index([isActive])
}

// ====================== PHASE 7 ENTERPRISE PRODUCTION ======================
model ProductionAreaRecord {
  id          String   @id @default(cuid())
  area        String
  feature     String
  code        String
  name        String
  description String?
  status      String   @default("ACTIVE")
  config      Json
  metrics     Json?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([area, feature, code])
  @@index([area])
  @@index([feature])
  @@index([status])
  @@index([createdAt])
}

model DashboardDefinition {
  id          String            @id @default(cuid())
  code        String            @unique
  name        String
  audience    String
  layout      Json
  filters     Json?
  isDefault   Boolean           @default(false)
  isActive    Boolean           @default(true)
  createdById String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  widgets     DashboardWidget[]

  @@index([audience])
  @@index([isActive])
}

model DashboardWidget {
  id          String              @id @default(cuid())
  dashboardId String
  type        String
  title       String
  dataSource  String
  config      Json
  position    Json
  filters     Json?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  dashboard   DashboardDefinition @relation(fields: [dashboardId], references: [id], onDelete: Cascade)

  @@index([dashboardId])
  @@index([type])
}

model WorkflowDefinition {
  id         String   @id @default(cuid())
  code       String   @unique
  name       String
  entity     String
  trigger    String
  mode       String   @default("SEQUENTIAL")
  steps      Json
  conditions Json?
  slaHours   Int?
  escalation Json?
  delegation Json?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([entity])
  @@index([mode])
  @@index([isActive])
}

model ReportDesign {
  id          String            @id @default(cuid())
  code        String            @unique
  name        String
  module      String
  definition  Json
  outputTypes Json
  filters     Json?
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  schedules   ScheduledReport[]

  @@index([module])
  @@index([isActive])
}

model ScheduledReport {
  id         String       @id @default(cuid())
  reportId   String
  cron       String
  recipients Json
  outputType String
  nextRunAt  DateTime?
  lastRunAt  DateTime?
  status     String       @default("ACTIVE")
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  report     ReportDesign @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([status])
  @@index([nextRunAt])
}

model NotificationTemplate {
  id         String              @id @default(cuid())
  code       String              @unique
  channel    String
  name       String
  subject    String?
  body       String
  variables  Json?
  isActive   Boolean             @default(true)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  deliveries NotificationQueue[]

  @@index([channel])
  @@index([isActive])
}

model NotificationQueue {
  id          String                @id @default(cuid())
  templateId  String?
  channel     String
  recipient   String
  payload     Json
  status      String                @default("PENDING")
  attempts    Int                   @default(0)
  maxAttempts Int                   @default(5)
  scheduledAt DateTime              @default(now())
  sentAt      DateTime?
  lastError   String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  template    NotificationTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([channel])
  @@index([scheduledAt])
}

model EnterpriseSearchIndex {
  id          String   @id @default(cuid())
  entity      String
  entityId    String
  title       String
  content     String
  keywords    Json?
  url         String?
  permissions Json?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@unique([entity, entityId])
  @@index([entity])
  @@index([updatedAt])
}

model FileCenterDocument {
  id         String              @id @default(cuid())
  code       String              @unique
  name       String
  category   String
  ownerType  String?
  ownerId    String?
  currentUrl String?
  status     String              @default("ACTIVE")
  expiresAt  DateTime?
  ocrText    String?
  metadata   Json?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  versions   FileCenterVersion[]

  @@index([category])
  @@index([status])
  @@index([expiresAt])
}

model FileCenterVersion {
  id          String             @id @default(cuid())
  documentId  String
  version     Int
  fileUrl     String
  fileName    String
  mimeType    String?
  sizeBytes   Int?
  checksum    String?
  approval    String             @default("PENDING")
  createdById String?
  createdAt   DateTime           @default(now())
  document    FileCenterDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, version])
  @@index([approval])
}

model BIInsight {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  metric    String
  dimension String?
  value     Float
  trend     Json?
  forecast  Json?
  heatmap   Json?
  period    String
  audience  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([metric])
  @@index([audience])
  @@index([period])
}

model AIPromptLibraryItem {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  category  String
  prompt    String
  variables Json?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([isActive])
}

model ApiGatewayEndpoint {
  id         String   @id @default(cuid())
  code       String   @unique
  version    String
  method     String
  path       String
  scopes     Json
  rateLimit  Int      @default(1000)
  webhookUrl String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([version])
  @@index([path])
  @@index([isActive])
}

model MonitoringMetric {
  id         String   @id @default(cuid())
  source     String
  metric     String
  value      Float
  unit       String?
  status     String   @default("OK")
  metadata   Json?
  capturedAt DateTime @default(now())

  @@index([source])
  @@index([metric])
  @@index([status])
  @@index([capturedAt])
}

model SecurityPolicy {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  type      String
  rules     Json
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([isActive])
}

model UserDevice {
  id         String   @id @default(cuid())
  userId     String
  deviceHash String
  name       String?
  userAgent  String?
  ipAddress  String?
  trusted    Boolean  @default(false)
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@unique([userId, deviceHash])
  @@index([userId])
  @@index([trusted])
}

model LoginHistory {
  id         String   @id @default(cuid())
  userId     String?
  identifier String?
  success    Boolean
  ipAddress  String?
  userAgent  String?
  reason     String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([success])
  @@index([createdAt])
}

// ====================== ENTERPRISE ERP PLATFORM EXTENSIONS ======================
model Tenant {
  id          String                     @id @default(cuid())
  code        String                     @unique
  name        String
  domain      String?                    @unique
  databaseUrl String?
  branding    Json?
  settings    Json?
  isActive    Boolean                    @default(true)
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt
  records     EnterprisePlatformRecord[]

  @@index([isActive])
}

model EnterprisePlatformRecord {
  id          String   @id @default(cuid())
  tenantId    String?
  suite       String
  feature     String
  code        String
  name        String
  status      String   @default("ACTIVE")
  priority    String   @default("NORMAL")
  payload     Json
  workflow    Json?
  approvals   Json?
  metrics     Json?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, suite, feature, code])
  @@index([suite])
  @@index([feature])
  @@index([status])
  @@index([tenantId])
}

model OpenApiDocument {
  id        String   @id @default(cuid())
  version   String
  title     String
  spec      Json
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([version, title])
  @@index([isActive])
}

model PlatformBackgroundJob {
  id          String    @id @default(cuid())
  queue       String
  name        String
  status      String    @default("PENDING")
  payload     Json
  attempts    Int       @default(0)
  maxAttempts Int       @default(5)
  runAt       DateTime  @default(now())
  lockedAt    DateTime?
  finishedAt  DateTime?
  lastError   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([queue])
  @@index([status])
  @@index([runAt])
}

model PlatformHealthMetric {
  id         String   @id @default(cuid())
  service    String
  metric     String
  value      Float
  unit       String?
  status     String   @default("OK")
  traceId    String?
  metadata   Json?
  capturedAt DateTime @default(now())

  @@index([service])
  @@index([metric])
  @@index([status])
  @@index([capturedAt])
}

// ====================== PHASE 4 ENTERPRISE INFRASTRUCTURE ======================
model EventStoreRecord {
  id            String    @id @default(cuid())
  tenantId      String?
  stream        String
  eventType     String
  aggregateType String
  aggregateId   String
  version       Int       @default(1)
  payload       Json
  metadata      Json?
  status        String    @default("PENDING")
  attempts      Int       @default(0)
  replayedAt    DateTime?
  deadLetterAt  DateTime?
  createdAt     DateTime  @default(now())

  @@index([tenantId])
  @@index([stream])
  @@index([eventType])
  @@index([aggregateType, aggregateId])
  @@index([status])
}

model MessageQueueRecord {
  id           String    @id @default(cuid())
  tenantId     String?
  provider     String
  queueName    String
  jobType      String
  payload      Json
  status       String    @default("PENDING")
  priority     Int       @default(5)
  attempts     Int       @default(0)
  maxAttempts  Int       @default(5)
  delayedUntil DateTime?
  lockedAt     DateTime?
  processedAt  DateTime?
  deadLetterAt DateTime?
  lastError    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([tenantId])
  @@index([provider])
  @@index([queueName])
  @@index([status])
  @@index([delayedUntil])
}

model SchedulerRecord {
  id        String    @id @default(cuid())
  tenantId  String?
  code      String    @unique
  name      String
  cron      String?
  calendar  Json?
  jobType   String
  payload   Json
  status    String    @default("ACTIVE")
  lastRunAt DateTime?
  nextRunAt DateTime?
  lastError String?
  history   Json?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([tenantId])
  @@index([status])
  @@index([nextRunAt])
}

model NotificationPipelineRecord {
  id          String    @id @default(cuid())
  tenantId    String?
  channel     String
  queueName   String
  recipient   String
  template    String?
  payload     Json
  status      String    @default("PENDING")
