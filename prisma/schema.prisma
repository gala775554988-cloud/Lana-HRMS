generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                    String                   @id @default(cuid())
  name                  String?
  username              String?                  @unique
  email                 String?                  @unique
  emailVerified         DateTime?
  image                 String?
  passwordHash          String?
  isActive              Boolean                  @default(true)
  lastLoginAt           DateTime?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  accounts              Account[]
  sessions              Session[]
  roles                 UserRole[]
  passwordResetTokens   PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  employeeProfile         Employee?
  auditLogs               AuditLog[]
  notifications           Notification[]

  @@index([username])
  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Role {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  isSystem    Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id          String           @id @default(cuid())
  action      String
  resource    String
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  roles       RolePermission[]

  @@unique([action, resource])
}

model UserRole {
  userId     String
  roleId     String
  assignedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String
  assignedAt   DateTime   @default(now())
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}


enum EmployeeStatus {
  ACTIVE
  ON_LEAVE
  TERMINATED
  INACTIVE
}

enum DocumentStatus {
  PENDING
  VERIFIED
  REJECTED
  EXPIRED
}

enum ContractStatus {
  DRAFT
  ACTIVE
  EXPIRED
  TERMINATED
}

model Department {
  id          String     @id @default(cuid())
  name        String
  code        String     @unique
  description String?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  employees   Employee[]
  positions   Position[]

  @@index([name])
}

model Position {
  id           String      @id @default(cuid())
  title        String
  code         String      @unique
  description  String?
  departmentId String?
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  employees    Employee[]

  @@index([title])
  @@index([departmentId])
}

model Branch {
  id        String     @id @default(cuid())
  name      String
  code      String     @unique
  address   String?
  city      String?
  country   String?
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  employees Employee[]

  @@index([name])
}

model EmploymentType {
  id          String     @id @default(cuid())
  name        String
  code        String     @unique
  description String?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  employees   Employee[]
}

model Nationality {
  id        String     @id @default(cuid())
  name      String
  code      String     @unique
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  employees Employee[]
}

model Employee {
  id               String             @id @default(cuid())
  employeeNumber   String             @unique
  nationalId       String             @unique
  firstName        String
  lastName         String
  email            String?            @unique
  profilePhotoUrl  String?
  phone            String?
  gender           String?
  dateOfBirth      DateTime?
  hireDate         DateTime
  terminationDate  DateTime?
  status           EmployeeStatus     @default(ACTIVE)
  address          String?
  emergencyContact String?
  userId           String?            @unique
  departmentId     String?
  positionId       String?
  branchId         String?
  employmentTypeId String?
  nationalityId    String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  user             User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  department       Department?        @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  position         Position?          @relation(fields: [positionId], references: [id], onDelete: SetNull)
  branch           Branch?            @relation(fields: [branchId], references: [id], onDelete: SetNull)
  employmentType   EmploymentType?    @relation(fields: [employmentTypeId], references: [id], onDelete: SetNull)
  nationality      Nationality?       @relation(fields: [nationalityId], references: [id], onDelete: SetNull)
  documents        EmployeeDocument[]
  contracts        EmployeeContract[]
  assignedAssets    Asset[]
  trainingEnrollments TrainingEnrollment[]
  evaluations       PerformanceEvaluation[]
  deductions        Deduction[]
  allowances        Allowance[]
  overtimeRequests  OvertimeRequest[]
  loans             Loan[]
  payrollItems      PayrollItem[]
  leaveRequests     LeaveRequest[]
  attendanceRecords AttendanceRecord[]
  preferences       EmployeePreference?
  workflowInstances WorkflowInstance[]
  expenseRequests   ExpenseRequest[]
  letterRequests    LetterRequest[]

  @@index([nationalId])
  @@index([firstName, lastName])
  @@index([status])
  @@index([departmentId])
  @@index([positionId])
  @@index([branchId])
}

model EmployeeDocument {
  id          String         @id @default(cuid())
  employeeId  String
  type        String
  name        String
  fileUrl     String
  fileName    String?
  mimeType    String?
  sizeBytes   Int?
  status      DocumentStatus @default(PENDING)
  expiresAt   DateTime?
  uploadedAt  DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  employee    Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([status])
}

model EmployeeContract {
  id             String         @id @default(cuid())
  employeeId     String
  contractNumber String         @unique
  title          String
  startDate      DateTime
  endDate        DateTime?
  salaryAmount   Decimal        @db.Decimal(12, 2)
  currency       String         @default("USD")
  status         ContractStatus @default(DRAFT)
  signedAt       DateTime?
  attachmentUrl  String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  employee       Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([status])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  action      String
  entity      String
  entityId    String?
  metadata    Json?
  createdAt   DateTime @default(now())
  actor       User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([entity, entityId])
  @@index([createdAt])
}


enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  REMOTE
  HOLIDAY
}

enum LeaveRequestStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum PayrollStatus {
  DRAFT
  PROCESSING
  APPROVED
  PAID
  CANCELLED
}

enum LoanStatus {
  ACTIVE
  PAID
  DEFAULTED
  CANCELLED
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum EvaluationStatus {
  DRAFT
  SUBMITTED
  APPROVED
}

enum CandidateStatus {
  APPLIED
  SCREENING
  INTERVIEW
  OFFERED
  HIRED
  REJECTED
}

enum TrainingStatus {
  PLANNED
  OPEN
  COMPLETED
  CANCELLED
}

enum AssetStatus {
  AVAILABLE
  ASSIGNED
  MAINTENANCE
  RETIRED
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
}

model AttendanceRecord {
  id         String           @id @default(cuid())
  employeeId String
  workDate   DateTime
  checkIn    DateTime?
  checkOut   DateTime?
  status     AttendanceStatus @default(PRESENT)
  notes      String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  employee   Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, workDate])
  @@index([workDate])
  @@index([status])
}

model LeaveType {
  id          String         @id @default(cuid())
  name        String
  code        String         @unique
  description String?
  annualLimit Int?
  isPaid      Boolean        @default(true)
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  requests    LeaveRequest[]
}

model LeaveRequest {
  id          String             @id @default(cuid())
  employeeId  String
  leaveTypeId String
  startDate   DateTime
  endDate     DateTime
  days        Decimal            @db.Decimal(6, 2)
  reason      String?
  status      LeaveRequestStatus @default(PENDING)
  decidedAt   DateTime?
  decisionNote String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  employee    Employee           @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType   LeaveType          @relation(fields: [leaveTypeId], references: [id], onDelete: Restrict)

  @@index([employeeId])
  @@index([leaveTypeId])
  @@index([status])
}

model PayrollRun {
  id        String       @id @default(cuid())
  name      String
  period    String
  status    PayrollStatus @default(DRAFT)
  paidAt    DateTime?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  items     PayrollItem[]

  @@unique([period])
  @@index([status])
}

model PayrollItem {
  id            String     @id @default(cuid())
  payrollRunId  String
  employeeId     String
  baseSalary     Decimal    @db.Decimal(12, 2)
  allowanceTotal Decimal    @db.Decimal(12, 2) @default(0)
  deductionTotal Decimal    @db.Decimal(12, 2) @default(0)
  overtimeTotal  Decimal    @db.Decimal(12, 2) @default(0)
  netPay         Decimal    @db.Decimal(12, 2)
  currency       String     @default("USD")
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  payrollRun     PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employee       Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([payrollRunId, employeeId])
  @@index([employeeId])
}

model Loan {
  id              String     @id @default(cuid())
  employeeId      String
  loanNumber      String     @unique
  principalAmount Decimal    @db.Decimal(12, 2)
  outstandingAmount Decimal  @db.Decimal(12, 2)
  installmentAmount Decimal  @db.Decimal(12, 2)
  currency        String     @default("USD")
  issuedAt        DateTime
  status          LoanStatus @default(ACTIVE)
  notes           String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  employee        Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([status])
}

model OvertimeRequest {
  id         String        @id @default(cuid())
  employeeId String
  workDate   DateTime
  hours      Decimal       @db.Decimal(6, 2)
  rate       Decimal       @db.Decimal(8, 2) @default(1.5)
  reason     String?
  status     RequestStatus @default(PENDING)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  employee   Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([status])
}

model Allowance {
  id          String   @id @default(cuid())
  employeeId  String
  name        String
  amount      Decimal  @db.Decimal(12, 2)
  currency    String   @default("USD")
  effectiveFrom DateTime
  effectiveTo DateTime?
  isRecurring Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

model Deduction {
  id          String   @id @default(cuid())
  employeeId  String
  name        String
  amount      Decimal  @db.Decimal(12, 2)
  currency    String   @default("USD")
  effectiveFrom DateTime
  effectiveTo DateTime?
  isRecurring Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

model PerformanceEvaluation {
  id          String           @id @default(cuid())
  employeeId  String
  period      String
  score       Decimal          @db.Decimal(5, 2)
  summary     String?
  goals       String?
  status      EvaluationStatus @default(DRAFT)
  evaluatedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  employee    Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, period])
  @@index([status])
}

model JobOpening {
  id           String      @id @default(cuid())
  title        String
  code         String      @unique
  departmentId String?
  branchId     String?
  description  String?
  status       String      @default("OPEN")
  openedAt     DateTime    @default(now())
  closedAt     DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  candidates   Candidate[]

  @@index([status])
}

model Candidate {
  id           String          @id @default(cuid())
  jobOpeningId String?
  firstName    String
  lastName     String
  email        String
  phone        String?
  resumeUrl    String?
  status       CandidateStatus @default(APPLIED)
  notes        String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  jobOpening   JobOpening?     @relation(fields: [jobOpeningId], references: [id], onDelete: SetNull)

  @@index([firstName, lastName])
  @@index([email])
  @@index([status])
}

model TrainingProgram {
  id          String               @id @default(cuid())
  title       String
  code        String               @unique
  provider    String?
  startDate   DateTime?
  endDate     DateTime?
  status      TrainingStatus       @default(PLANNED)
  description String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  enrollments TrainingEnrollment[]
}

model TrainingEnrollment {
  id                String          @id @default(cuid())
  trainingProgramId String
  employeeId         String
  status             TrainingStatus @default(OPEN)
  completedAt        DateTime?
  score              Decimal?       @db.Decimal(5, 2)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  trainingProgram    TrainingProgram @relation(fields: [trainingProgramId], references: [id], onDelete: Cascade)
  employee           Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([trainingProgramId, employeeId])
  @@index([employeeId])
}

model Asset {
  id                 String      @id @default(cuid())
  assetTag           String      @unique
  name               String
  category           String
  serialNumber       String?
  status             AssetStatus @default(AVAILABLE)
  assignedEmployeeId String?
  assignedAt         DateTime?
  returnedAt         DateTime?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  assignedEmployee   Employee?   @relation(fields: [assignedEmployeeId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([assignedEmployeeId])
}

model Announcement {
  id          String   @id @default(cuid())
  title       String
  body        String
  audience    String   @default("ALL")
  publishedAt DateTime?
  expiresAt   DateTime?
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isPublished])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String?
  title     String
  body      String
  type      NotificationType @default(INFO)
  readAt    DateTime?
  createdAt DateTime         @default(now())
  user      User?            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([readAt])
}

model ReportDefinition {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  description String?
  module      String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AppSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  description String?
  isSecret    Boolean  @default(false)
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}

// ====================== EMPLOYEE PREFERENCES & THEMES ======================
model EmployeePreference {
  id            String   @id @default(cuid())
  employeeId    String   @unique
  theme         String   @default("corporate")
  language      String   @default("ar")
  timezone      String   @default("Asia/Riyadh")
  notifications Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

// ====================== SEPARATE REQUEST TABLES ======================
model ExpenseRequest {
  id          String         @id @default(cuid())
  employeeId  String
  amount      Decimal        @db.Decimal(12, 2)
  category    String
  description String?
  receiptUrl  String?
  status      RequestStatus  @default(PENDING)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  employee    Employee       @relation(fields: [employeeId], references: [id])
}

model LetterRequest {
  id          String        @id @default(cuid())
  employeeId  String
  letterType  String
  purpose     String?
  status      RequestStatus @default(PENDING)
  fileUrl     String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  employee    Employee      @relation(fields: [employeeId], references: [id])
}

// ====================== WORKFLOW ENGINE ======================
model WorkflowInstance {
  id          String   @id @default(cuid())
  employeeId  String
  type        String   // LEAVE | EXPENSE | LOAN | LETTER
  entityId    String
  status      String   @default("PENDING")
  currentStep Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  employee    Employee @relation(fields: [employeeId], references: [id])
  steps       WorkflowStep[]
}

model WorkflowStep {
  id                 String    @id @default(cuid())
  workflowInstanceId String
  step               Int
  approverUserId     String?
  status             String    @default("PENDING") // PENDING | APPROVED | REJECTED
  approvedAt         DateTime?
  comments           String?
  createdAt          DateTime  @default(now())
  workflowInstance   WorkflowInstance @relation(fields: [workflowInstanceId], references: [id], onDelete: Cascade)
}

// ====================== ENTERPRISE UPGRADE MODELS ======================

model Hospital {
  id             String    @id @default(cuid())
  name           String
  code           String    @unique
  logoUrl        String?
  medicalDepts   String?
  bedsCount      Int       @default(0)
  capacity       Int       @default(0)
  phone          String?
  email          String?
  address        String?
  city           String?
  branchId       String?
  managerId      String?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model DynamicField {
  id             String    @id @default(cuid())
  module         String    // e.g., "EMPLOYEE", "DEPARTMENT"
  fieldName      String
  fieldType      String    // e.g., "TEXT", "NUMBER", "DATE", "SELECT"
  options        Json?
  isRequired     Boolean   @default(false)
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model AILog {
  id             String    @id @default(cuid())
  action         String
  prompt         String?   @db.Text
  response       String?   @db.Text
  userId         String?
  createdAt      DateTime  @default(now())
}

// ====================== ENTERPRISE ERP INTEGRATIONS ======================
model IntegrationProvider {
  id          String                  @id @default(cuid())
  name        String
  code        String                  @unique
  type        String                  @default("ODOO")
  baseUrl     String
  authType    String                  @default("ODOO_JSON_RPC")
  isActive    Boolean                 @default(true)
  metadata    Json?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  connections IntegrationConnection[]
  mappings    IntegrationMapping[]
  jobs        IntegrationJob[]
  queues      IntegrationQueue[]
  webhooks    IntegrationWebhook[]
  apiKeys     IntegrationApiKey[]
  oauthClients IntegrationOAuthClient[]
  settings    IntegrationSetting[]
  logs        IntegrationLog[]

  @@index([type])
  @@index([isActive])
}

model IntegrationConnection {
  id             String                @id @default(cuid())
  providerId     String
  name           String
  baseUrl        String
  database       String?
  username       String?
  uid            Int?
  sessionId      String?
  secretCipher   String?
  status         String                @default("DISCONNECTED")
  lastTestAt     DateTime?
  lastError      String?
  version        Json?
  metadata       Json?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  provider       IntegrationProvider   @relation(fields: [providerId], references: [id], onDelete: Cascade)
  mappings       IntegrationMapping[]
  jobs           IntegrationJob[]
  queues         IntegrationQueue[]
  syncHistories  SyncHistory[]
  conflicts      ConflictLog[]
  logs           IntegrationLog[]

  @@index([providerId])
  @@index([status])
}

model IntegrationMapping {
  id              String                @id @default(cuid())
  providerId      String
  connectionId    String?
  name            String
  hrmsModule      String
  hrmsModel       String
  externalModel   String
  direction       String                @default("BIDIRECTIONAL")
  keyField        String                @default("id")
  externalKeyField String               @default("id")
  fieldMap        Json
  transformMap    Json?
  isActive        Boolean               @default(true)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  provider        IntegrationProvider   @relation(fields: [providerId], references: [id], onDelete: Cascade)
  connection      IntegrationConnection? @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  jobs            IntegrationJob[]
  queues          IntegrationQueue[]
  syncHistories   SyncHistory[]
  conflicts       ConflictLog[]

  @@index([providerId])
  @@index([connectionId])
  @@index([hrmsModule])
  @@index([externalModel])
  @@index([isActive])
}

model IntegrationJob {
  id             String                 @id @default(cuid())
  providerId     String?
  connectionId   String?
  mappingId      String?
  name           String
  type           String
  status         String                 @default("PENDING")
  direction      String                 @default("BIDIRECTIONAL")
  schedule       String?
  payload        Json?
  result         Json?
  attempts       Int                    @default(0)
  maxAttempts    Int                    @default(3)
  runAt          DateTime?
  startedAt      DateTime?
  finishedAt     DateTime?
  lastError      String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
