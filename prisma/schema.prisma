generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                      String                   @id @default(cuid())
  name                    String?
  username                String?                  @unique
  email                   String?                  @unique
  emailVerified           DateTime?
  image                   String?
  passwordHash            String?
  isActive                Boolean                  @default(true)
  lastLoginAt             DateTime?
  mustChangePassword      Boolean                  @default(false)
  passwordChanged         Boolean                  @default(true)
  passwordChangedAt       DateTime?
  lastPasswordResetBy     String?
  lastPasswordResetAt     DateTime?
  isLocked                Boolean                  @default(false)
  lockedReason            String?
  lockedAt                DateTime?
  lockedById              String?
  canUseMultipleDevices   Boolean                  @default(false)
  loginAttempts           Int                      @default(0)
  lastFailedLoginAt       DateTime?
  loginCount              Int                      @default(0)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  accounts                Account[]
  sessions                Session[]
  roles                   UserRole[]
  customPermissions       UserPermission[]
  grantedPermissions      UserPermission[]         @relation("PermissionGrantedBy")
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  employeeProfile         Employee?
  auditLogs               AuditLog[]
  notifications           Notification[]

  @@index([username])
  @@index([email])
  @@index([mustChangePassword])
  @@index([passwordChanged])
  @@index([isLocked])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Role {
  id                  String               @id @default(cuid())
  name                String               @unique
  description         String?
  isSystem            Boolean              @default(false)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  users               UserRole[]
  permissions         RolePermission[]
}

model Permission {
  id              String               @id @default(cuid())
  action          String
  resource        String
  description     String?
  groupCode       String?
  isSystem        Boolean              @default(false)
  sortOrder       Int                  @default(0)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  roles           RolePermission[]
  userPermissions UserPermission[]

  @@unique([action, resource])
  @@index([groupCode])
  @@index([isSystem])
}

model PermissionGroup {
  id          String   @id @default(cuid())
  code        String   @unique
  key         String?  @unique
  name        String
  nameAr      String?
  description String?
  icon        String?
  parentId    String?
  isSystem    Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([code])
  @@index([key])
}

model UserPermission {
  id           String     @id @default(cuid())
  userId       String
  permissionId String
  isGranted    Boolean    @default(true)
  grantedById  String?
  grantedAt    DateTime   @default(now())
  expiresAt    DateTime?
  reason       String?
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  grantedBy    User?      @relation("PermissionGrantedBy", fields: [grantedById], references: [id], onDelete: SetNull)

  @@unique([userId, permissionId])
  @@index([userId])
  @@index([permissionId])
  @@index([isGranted])
}


model UserRole {
  userId     String
  roleId     String
  assignedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String
  assignedAt   DateTime   @default(now())
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

enum EmployeeStatus {
  ACTIVE
  ON_LEAVE
  TERMINATED
  INACTIVE
}

enum DocumentStatus {
  PENDING
  VERIFIED
  REJECTED
  EXPIRED
}

enum ContractStatus {
  DRAFT
  ACTIVE
  EXPIRED
  TERMINATED
}

enum InsuranceStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

model Department {
  id            String     @id @default(cuid())
  name          String
  code          String     @unique
  description   String?
  isActive      Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  employees     Employee[]
  positions     Position[]
  odooId        Int?       @unique
  odooWriteDate DateTime?
  odooActive    Boolean?

  @@index([name])
  @@index([odooId])
}

model Position {
  id               String      @id @default(cuid())
  title            String
  code             String      @unique
  description      String?
  departmentId     String?
  isActive         Boolean     @default(true)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  department       Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  employees        Employee[]
  odooId           Int?        @unique
  odooWriteDate    DateTime?
  odooDepartmentId Int?

  @@index([title])
  @@index([departmentId])
  @@index([odooId])
}

model Branch {
  id            String     @id @default(cuid())
  name          String
  code          String     @unique
  address       String?
  city          String?
  country       String?
  isActive      Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  employees     Employee[]
  odooId        Int?       @unique
  odooWriteDate DateTime?
  odooActive    Boolean?

  @@index([name])
  @@index([odooId])
}

model EmploymentType {
  id          String     @id @default(cuid())
  name        String
  code        String     @unique
  description String?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  employees   Employee[]
}

model Nationality {
  id        String     @id @default(cuid())
  name      String
  code      String     @unique
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  employees Employee[]
}

model Employee {
  id                     String                  @id @default(cuid())
  employeeNumber         String                  @unique
  nationalId             String                  @unique
  firstName              String
  lastName               String
  email                  String?                 @unique
  profilePhotoUrl        String?
  phone                  String?
  gender                 String?
  dateOfBirth            DateTime?
  hireDate               DateTime
  terminationDate        DateTime?
  status                 EmployeeStatus          @default(ACTIVE)
  address                String?
  emergencyContact       String?
  userId                 String?                 @unique
  departmentId           String?
  positionId             String?
  branchId               String?
  employmentTypeId       String?
  nationalityId          String?
  // Odoo sync fields
  sponsor                String? // كفيل / Sponsor name synced from Odoo
  hospitalId             String? // Real FK, replaces the old freeform employee.extra AppSetting hospital string
  costCenter             String? // Freeform for now -- Odoo field mapping deferred pending real custom field name
  analyticAccount        String? // Freeform for now -- Odoo field mapping deferred pending real custom field name
  workLocationName       String? // Mirrors Odoo's work_location_id (fetched but previously unmapped)
  odooWorkLocationId     Int?
  // Archived employees & last active date
  managerId              String?
  lastActiveDate         DateTime?
  lastActiveSource       String? // e.g., "ODOO", "ATTENDANCE", "LEAVE", "TIMESHEET"
  archivedAt             DateTime?
  archiveReason          String?
  isPendingActivation    Boolean                 @default(false)
  pendingActivationUntil DateTime?
  // Odoo Source of Truth fields
  odooId                 Int?                    @unique
  odooWriteDate          DateTime?
  odooCreateDate         DateTime?
  odooActive             Boolean?
  odooDepartmentId       Int?
  odooJobId              Int?
  odooCompanyId          Int?
  odooParentId           Int?
  // Full dynamic snapshot of all non-bank hr.employee fields (standard + custom) as returned by Odoo
  odooRawData            Json?
  odooRawDataSyncedAt    DateTime?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  user                   User?                   @relation(fields: [userId], references: [id], onDelete: SetNull)
  department             Department?             @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  position               Position?               @relation(fields: [positionId], references: [id], onDelete: SetNull)
  branch                 Branch?                 @relation(fields: [branchId], references: [id], onDelete: SetNull)
  employmentType         EmploymentType?         @relation(fields: [employmentTypeId], references: [id], onDelete: SetNull)
  nationality            Nationality?            @relation(fields: [nationalityId], references: [id], onDelete: SetNull)
  manager                Employee?               @relation("EmployeeManager", fields: [managerId], references: [id], onDelete: SetNull)
  managedEmployees       Employee[]              @relation("EmployeeManager")
  hospital               Hospital?               @relation(fields: [hospitalId], references: [id], onDelete: SetNull)
  shiftAssignments       ShiftAssignment[]
  documents              EmployeeDocument[]
  contracts              EmployeeContract[]
  insurancePolicies      InsurancePolicy[]
  assignedAssets         Asset[]
  trainingEnrollments    TrainingEnrollment[]
  evaluations            PerformanceEvaluation[]
  deductions             Deduction[]
  allowances             Allowance[]
  overtimeRequests       OvertimeRequest[]
  loans                  Loan[]
  payrollItems           PayrollItem[]
  leaveRequests          LeaveRequest[]
  resumptionRequests     ResumptionRequest[]
  attendanceRecords      AttendanceRecord[]
  preferences            EmployeePreference?
  mobileDevice           EmployeeMobileDevice?
  workflowInstances      WorkflowInstance[]
  expenseRequests        ExpenseRequest[]
  letterRequests         LetterRequest[]

  bankAccounts           EmployeeBankAccount[]
  familyMembers          EmployeeFamilyMember[]
  qualifications         EmployeeQualification[]
  experiences            EmployeeExperience[]
  skills                 EmployeeSkill[]
  languages              EmployeeLanguage[]
  permissionRequests     EmployeePermissionRequest[]
  portalTasks            EmployeePortalTask[]
  chatThreads            EmployeeChatThread[]
  employeeSalaryAdvances EmployeeSalaryAdvance[]
  employeeComplaints     EmployeeComplaint[]

  @@index([nationalId])
  @@index([firstName, lastName])
  @@index([status])
  @@index([departmentId])
  @@index([positionId])
  @@index([branchId])
  @@index([email])
  @@index([employeeNumber])
  @@index([lastActiveDate])
  @@index([archivedAt])
  @@index([managerId])
  @@index([isPendingActivation])
  @@index([pendingActivationUntil])
  @@index([hireDate])
  @@index([createdAt])
  @@index([status, departmentId])
  @@index([status, branchId])
  @@index([hospitalId])
}

model EmployeeDocument {
  id               String         @id @default(cuid())
  employeeId       String
  type             String
  name             String
  fileUrl          String
  fileName         String?
  mimeType         String?
  sizeBytes        Int?
  status           DocumentStatus @default(PENDING)
  expiresAt        DateTime?
  uploadedAt       DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  employee         Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  source           String         @default("MANUAL")
  odooAttachmentId Int?           @unique

  @@index([employeeId])
  @@index([status])
}

model EmployeeContract {
  id             String         @id @default(cuid())
  employeeId     String
  contractNumber String         @unique
  title          String
  startDate      DateTime
  endDate        DateTime?
  salaryAmount   Decimal        @db.Decimal(12, 2)
  currency       String         @default("USD")
  status         ContractStatus @default(DRAFT)
  signedAt       DateTime?
  attachmentUrl  String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  employee       Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  odooId         Int?           @unique
  odooEmployeeId Int?
  odooWriteDate  DateTime?
  odooState      String?
  odooRawData    Json?

  @@index([employeeId])
  @@index([status])
  @@index([odooId])
  @@index([odooEmployeeId])
}

model InsurancePolicy {
  id           String          @id @default(cuid())
  employeeId   String
  policyNumber String          @unique
  provider     String
  coverageType String?
  startDate    DateTime
  endDate      DateTime
  status       InsuranceStatus @default(ACTIVE)
  documentUrl  String?
  documentName String?
  notes        String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  employee     Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  // Backs the "policy renewal due soon" badge: status = ACTIVE AND endDate <= cutoff.
  @@index([status, endDate])
}

model SalaryStructure {
  id          String            @id @default(cuid())
  code        String            @unique
  name        String
  description String?
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  components  SalaryComponent[]

  @@index([code])
  @@index([isActive])
}

model SalaryComponent {
  id          String          @id @default(cuid())
  structureId String
  code        String
  name        String
  type        String // EARNING, DEDUCTION
  amountType  String // FIXED, PERCENTAGE, FORMULA
  amount      Decimal?        @db.Decimal(12, 2)
  formula     String?
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  structure   SalaryStructure @relation(fields: [structureId], references: [id], onDelete: Cascade)

  @@unique([structureId, code])
  @@index([structureId])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  action      String
  entity      String
  entityId    String?
  metadata    Json?
  createdAt   DateTime @default(now())
  actor       User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([entity, entityId])
  @@index([createdAt])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  REMOTE
  HOLIDAY
}

enum LeaveRequestStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum PayrollStatus {
  DRAFT
  PROCESSING
  APPROVED
  PAID
  CANCELLED
}

enum LoanStatus {
  ACTIVE
  PAID
  DEFAULTED
  CANCELLED
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum EvaluationStatus {
  DRAFT
  SUBMITTED
  APPROVED
}

enum CandidateStatus {
  APPLIED
  SCREENING
  INTERVIEW
  OFFERED
  HIRED
  REJECTED
}

enum TrainingStatus {
  PLANNED
  OPEN
  COMPLETED
  CANCELLED
}

enum AssetStatus {
  AVAILABLE
  ASSIGNED
  MAINTENANCE
  RETIRED
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
}

model AttendanceRecord {
  id         String           @id @default(cuid())
  employeeId String
  workDate   DateTime
  checkIn    DateTime?
  checkOut   DateTime?
  status     AttendanceStatus @default(PRESENT)
  notes      String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  employee   Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, workDate])
  @@index([workDate])
  @@index([status])
}

model LeaveType {
  id          String         @id @default(cuid())
  name        String
  code        String         @unique
  description String?
  annualLimit Int?
  isPaid      Boolean        @default(true)
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  requests    LeaveRequest[]
}

model LeaveRequest {
  id           String             @id @default(cuid())
  employeeId   String
  leaveTypeId  String
  startDate    DateTime
  endDate      DateTime
  days         Decimal            @db.Decimal(6, 2)
  reason       String?
  status       LeaveRequestStatus @default(PENDING)
  decidedAt    DateTime?
  decisionNote String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  employee     Employee           @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType    LeaveType          @relation(fields: [leaveTypeId], references: [id], onDelete: Restrict)

  @@index([employeeId])
  @@index([leaveTypeId])
  @@index([status])
}

model ResumptionRequest {
  id              String   @id @default(cuid())
  employeeId      String
  leaveRequestId  String?
  returnDate      DateTime
  resumptionType  String   @default("AFTER_LEAVE") // AFTER_LEAVE | AFTER_MISSION | AFTER_SICK | OTHER
  reason          String?
  notes           String?
  status          String   @default("PENDING") // PENDING | APPROVED | REJECTED | RETURNED
  decidedAt       DateTime?
  decisionNote    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([status])
}

model PayrollRun {
  id        String        @id @default(cuid())
  name      String
  period    String
  status    PayrollStatus @default(DRAFT)
  paidAt    DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  items     PayrollItem[]

  @@unique([period])
  @@index([status])
}

model PayrollItem {
  id             String     @id @default(cuid())
  payrollRunId   String
  employeeId     String
  baseSalary     Decimal    @db.Decimal(12, 2)
  allowanceTotal Decimal    @default(0) @db.Decimal(12, 2)
  deductionTotal Decimal    @default(0) @db.Decimal(12, 2)
  overtimeTotal  Decimal    @default(0) @db.Decimal(12, 2)
  netPay         Decimal    @db.Decimal(12, 2)
  currency       String     @default("USD")
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  payrollRun     PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employee       Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  odooPayslipId  Int?       @unique
  odooRawData    Json?

  @@unique([payrollRunId, employeeId])
  @@index([employeeId])
}

model Loan {
  id                String     @id @default(cuid())
  employeeId        String
  loanNumber        String     @unique
  principalAmount   Decimal    @db.Decimal(12, 2)
  outstandingAmount Decimal    @db.Decimal(12, 2)
  installmentAmount Decimal    @db.Decimal(12, 2)
  currency          String     @default("USD")
  issuedAt          DateTime
  status            LoanStatus @default(ACTIVE)
  notes             String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  employee          Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([status])
}

model OvertimeRequest {
  id         String        @id @default(cuid())
  employeeId String
  workDate   DateTime
  hours      Decimal       @db.Decimal(6, 2)
  rate       Decimal       @default(1.5) @db.Decimal(8, 2)
  reason     String?
  status     RequestStatus @default(PENDING)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  employee   Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([status])
}

model Allowance {
  id               String    @id @default(cuid())
  employeeId       String
  name             String
  amount           Decimal   @db.Decimal(12, 2)
  currency         String    @default("USD")
  effectiveFrom    DateTime
  effectiveTo      DateTime?
  isRecurring      Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  employee         Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  source           String    @default("MANUAL")
  odooPayslipLineId Int?     @unique

  @@index([employeeId])
}

model Deduction {
  id               String    @id @default(cuid())
  employeeId       String
  name             String
  amount           Decimal   @db.Decimal(12, 2)
  currency         String    @default("USD")
  effectiveFrom    DateTime
  effectiveTo      DateTime?
  isRecurring      Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  employee         Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  source           String    @default("MANUAL")
  odooPayslipLineId Int?     @unique

  @@index([employeeId])
}

model PerformanceEvaluation {
  id          String           @id @default(cuid())
  employeeId  String
  period      String
  score       Decimal          @db.Decimal(5, 2)
  summary     String?
  goals       String?
  status      EvaluationStatus @default(DRAFT)
  evaluatedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  employee    Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, period])
  @@index([status])
}

model JobOpening {
  id           String      @id @default(cuid())
  title        String
  code         String      @unique
  departmentId String?
  branchId     String?
  description  String?
  status       String      @default("OPEN")
  openedAt     DateTime    @default(now())
  closedAt     DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  candidates   Candidate[]

  @@index([status])
}

model Candidate {
  id           String          @id @default(cuid())
  jobOpeningId String?
  firstName    String
  lastName     String
  email        String
  phone        String?
  resumeUrl    String?
  status       CandidateStatus @default(APPLIED)
  notes        String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  jobOpening   JobOpening?     @relation(fields: [jobOpeningId], references: [id], onDelete: SetNull)

  @@index([firstName, lastName])
  @@index([email])
  @@index([status])
}

model TrainingProgram {
  id          String               @id @default(cuid())
  title       String
  code        String               @unique
  provider    String?
  startDate   DateTime?
  endDate     DateTime?
  status      TrainingStatus       @default(PLANNED)
  description String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  enrollments TrainingEnrollment[]
}

model TrainingEnrollment {
  id                String          @id @default(cuid())
  trainingProgramId String
  employeeId        String
  status            TrainingStatus  @default(OPEN)
  completedAt       DateTime?
  score             Decimal?        @db.Decimal(5, 2)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  trainingProgram   TrainingProgram @relation(fields: [trainingProgramId], references: [id], onDelete: Cascade)
  employee          Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([trainingProgramId, employeeId])
  @@index([employeeId])
}

model Asset {
  id                 String      @id @default(cuid())
  assetTag           String      @unique
  name               String
  category           String
  serialNumber       String?
  status             AssetStatus @default(AVAILABLE)
  assignedEmployeeId String?
  assignedAt         DateTime?
  returnedAt         DateTime?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  assignedEmployee   Employee?   @relation(fields: [assignedEmployeeId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([assignedEmployeeId])
}

model Announcement {
  id          String    @id @default(cuid())
  title       String
  body        String
