// ====================== WORKFLOW ENGINE ======================
model WorkflowInstance {
  id          String         @id @default(cuid())
  employeeId  String
  type        String // LEAVE | EXPENSE | LOAN | LETTER
  entityId    String
  status      String         @default("PENDING")
  currentStep Int            @default(1)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  employee    Employee       @relation(fields: [employeeId], references: [id])
  steps       WorkflowStep[]
}

model WorkflowStep {
  id                 String           @id @default(cuid())
  workflowInstanceId String
  step               Int
  approverUserId     String?
  status             String           @default("PENDING") // PENDING | APPROVED | REJECTED
  approvedAt         DateTime?
  comments           String?
  createdAt          DateTime         @default(now())
  viewedAt           DateTime?
  capabilities       String[]         @default(["APPROVE", "REJECT"]) // Snapshot of what this step's approver may do, resolved from HrApprovalChain at creation time
  workflowInstance   WorkflowInstance @relation(fields: [workflowInstanceId], references: [id], onDelete: Cascade)

  @@index([approverUserId, status])
}

