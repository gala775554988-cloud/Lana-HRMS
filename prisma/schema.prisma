// HR ENTERPRISE PERMISSION SYSTEM (new tables only)
// ═══════════════════════════════════════════════════════════

model HrPermissionScope {
  id        String   @id @default(cuid())
  userId    String
  module    String   // employees, attendance, payroll, leaves, etc
  scope     String   @default("ALL") // ALL, BRANCH, DEPARTMENT, HOSPITAL, TEAM, SELF
  branchId  String?
  departmentId String?
  hospitalId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, module])
  @@index([userId])
  @@index([module])
}

model HrApprovalChain {
  id        String   @id @default(cuid())
  module    String   // leave, overtime, loan, expense, etc
  level     Int      @default(1)
  approverRole String @default("DIRECT_MANAGER") // DIRECT_MANAGER, DEPARTMENT_MANAGER, BRANCH_MANAGER, HR_MANAGER, SUPER_ADMIN -- used when approverUserId is not set
  approverUserId String? // Specific named person for this level; takes priority over approverRole
  scopeType String  @default("GLOBAL") // GLOBAL | BRANCH | HOSPITAL -- narrows this level to requests from a specific branch/hospital
  scopeId   String  @default("") // Branch.id or Hospital.id when scopeType != GLOBAL; "" (not null) so the unique index below behaves predictably
  capabilities String[] @default(["VIEW", "APPROVE", "REJECT"]) // What this level's approver can do: VIEW (see only), APPROVE, REJECT
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([module, level, scopeType, scopeId])
  @@index([module])
  @@index([approverUserId])
}

model HrPermissionAudit {
  id        String   @id @default(cuid())
  userId    String
  action    String
  module    String?
  oldValue  String?
  newValue  String?
  byUserId  String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

enum WorkflowPathType {
  HOSPITAL_PATH
  GENERAL_ADMIN_PATH
}

// One configurable named approval path per type (محرر مسارات الموافقات) --
// @unique on workflowType makes each type a single, replaceable record ("المسار
// الأول" / "المسار الثاني"). `steps` holds the ordered chain as JSON:
// [{ stepOrder, approverId, departmentId, roleContext }, ...].
model WorkflowPathTemplate {
  id           String           @id @default(cuid())
  workflowType WorkflowPathType @unique
  workflowName String
  steps        Json
  updatedById  String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([workflowType])
}
