  @@unique([tenantId, region, role])
  @@index([region])
  @@index([status])
}

model ZeroTrustPolicy {
  id            String   @id @default(cuid())
  tenantId      String?
  code          String
  name          String
  policyType    String
  conditions    Json
  actions       Json
  riskThreshold Float    @default(0.5)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([policyType])
  @@index([isActive])
}

// ====================== EMPLOYEE PORTAL ENTERPRISE MODELS ======================
model EmployeeBankAccount {
  id         String   @id @default(cuid())
  employeeId String
  bank       String
  iban       String
  account    String?
  isPrimary  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

model EmployeeFamilyMember {
  id                 String    @id @default(cuid())
  employeeId         String
  relation           String
  name               String
  nationalId         String?
  phone              String?
  dateOfBirth        DateTime?
  isEmergencyContact Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  employee           Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

model EmployeeQualification {
  id            String    @id @default(cuid())
  employeeId    String
  title         String
  organization  String?
  field         String?
  fromDate      DateTime?
  toDate        DateTime?
  attachmentUrl String?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  employee      Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

model EmployeeExperience {
  id           String    @id @default(cuid())
  employeeId   String
  title        String
  organization String?
  fromDate     DateTime?
  toDate       DateTime?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  employee     Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

model EmployeeSkill {
  id         String   @id @default(cuid())
  employeeId String
  name       String
  level      Int      @default(1)
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, name])
}

model EmployeeLanguage {
  id         String   @id @default(cuid())
  employeeId String
  name       String
  level      String   @default("BASIC")
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, name])
}

model EmployeePermissionRequest {
  id                String    @id @default(cuid())
  employeeId        String
  requestDate       DateTime
  fromTime          String
  toTime            String
  reason            String
  status            String    @default("PENDING_MANAGER")
  managerApprovedAt DateTime?
  hrApprovedAt      DateTime?
  rejectedAt        DateTime?
  workflow          Json?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  employee          Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([status])
}

model EmployeePortalTask {
  id          String                         @id @default(cuid())
  employeeId  String
  title       String
  status      String                         @default("PENDING")
  progress    Int                            @default(0)
  dueDate     DateTime?
  source      String?
  createdAt   DateTime                       @default(now())
  updatedAt   DateTime                       @updatedAt
  employee    Employee                       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  comments    EmployeePortalTaskComment[]
  attachments EmployeePortalTaskAttachment[]

  @@index([employeeId])
  @@index([status])
}

model EmployeePortalTaskComment {
  id           String             @id @default(cuid())
  taskId       String
  authorUserId String?
  body         String
  createdAt    DateTime           @default(now())
  task         EmployeePortalTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model EmployeePortalTaskAttachment {
  id        String             @id @default(cuid())
  taskId    String
  fileName  String
  fileUrl   String
  mimeType  String?
  sizeBytes Int?
  createdAt DateTime           @default(now())
  task      EmployeePortalTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model EmployeeChatThread {
  id              String                @id @default(cuid())
  employeeId      String
  participantType String
  subject         String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  employee        Employee              @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  messages        EmployeeChatMessage[]

  @@index([employeeId])
}

model EmployeeChatMessage {
  id           String             @id @default(cuid())
  threadId     String
  senderUserId String?
  body         String?
  fileName     String?
  fileUrl      String?
  mimeType     String?
  createdAt    DateTime           @default(now())
  thread       EmployeeChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId])
}
