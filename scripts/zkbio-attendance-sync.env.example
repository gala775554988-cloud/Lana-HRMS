# Copy this file to zkbio-attendance-sync.env (same folder) and fill in real
# values. This file is loaded by zkbio-attendance-sync.mjs -- it is NOT read
# by the Next.js app, so it does not need to match .env.local's format.

# ZKBio Time server address (LAN only -- do not expose this to the internet)
ZKBIO_URL=http://192.168.0.253:8081
ZKBIO_USERNAME=
ZKBIO_PASSWORD=

# Only change these if you verify (via browser DevTools Network tab while
# logging into ZKBio Time) that the real paths are different.
ZKBIO_LOGIN_PATH=/jwt-api-token-auth/
ZKBIO_TRANSACTIONS_PATH=/iclock/api/transactions/

# Lana HRMS production URL and the shared secret for this integration --
# generate a long random string and set the same value as ZKBIO_SYNC_TOKEN in
# Vercel's project environment variables.
LANA_URL=https://lana-hrms.vercel.app
ZKBIO_SYNC_TOKEN=

# How far back to look on the very first run (in minutes), since there's no
# previous sync timestamp yet. Every run after that only asks for transactions
# since the last successful run.
LOOKBACK_MINUTES_FIRST_RUN=120
